#!/usr/bin/env bash

main()
{
    dirname "$(dirname "$(dirname "$(dirname "$(readlink -f "${BASH_SOURCE}")")")")"
}

bin()
{
    echo "$(main)/bin"
}

COMMIT_MSG_FILE="$1"
MESSAGE="$(cat "${COMMIT_MSG_FILE}")"

# Check git config first (repo-scoped), fall back to env var (legacy / backward compat)
_legacy="$(git config --get hook.legacyCommitMessage 2>/dev/null)"
if [[ -z "$_legacy" ]]; then
    [[ "${LEGACY_COMMIT_MESSAGE:-0}" -ne 1 ]] || exit 0
else
    [[ "$_legacy" != "true" ]] || exit 0
fi
unset _legacy

result="$("$(bin)"/cog verify "${MESSAGE}" |& cat)"
echo "$result"

if echo "${result}" | grep -q "(not committed) - now"; then
    echo "${MESSAGE}" | "$(bin)"/insert-icon > "${COMMIT_MSG_FILE}"
else
    echo "See https://www.conventionalcommits.org/en/v1.0.0"
    exit 1
fi
